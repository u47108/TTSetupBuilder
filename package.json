{
  "name": "ttsetupbuilder",
  "private": true,
  "version": "0.1.0",
  "description": "Visual table tennis equipment database and setup builder",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "scrape": "pnpm --filter @ttsetupbuilder/scrapers scrape",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
